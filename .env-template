# Google OAuth Credentials for Gemini Enterprise API Explorer
# Create these under APIs & Services > Credentials in your GCP console.
GOOGLE_CLIENT_ID="your-oauth-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-oauth-client-secret-here"

# Google Cloud Project Details
GOOGLE_PROJECT_NUMBER="your-gcp-project-number-here"

# Optional Server Settings
# PORT=3400
# HOST=127.0.0.1
